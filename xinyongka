  return {
    type: 'stack',
    direction: 'column',
    flex: 1,
    gap: compact ?
    6 : 8,
    padding: compact ? 11 : 14,
    backgroundColor: C.card,
    borderRadius: 8,
    borderWidth: 1,
    borderColor: C.line,
    children: [
      {
        type: 'stack',
        direction: 'row',
        alignItems: 'center',
        gap: 6,
        children: [
          icon('creditcard.fill', color, compact 
          ? 14 : 17),
          txt(name, compact ? 12 : 15, 'bold'),
          { type: 'spacer' },
          txt(`••${tail}`, 10, 'medium', C.sub),
        ],
      },
      {
        type: 'stack',
        direction: 'row',
        alignItems: 'end',
        children: [
          txt(data.days, compact ? 27 : 34, 'bold', color),
          txt('天', compact ? 12 : 14, 'semibold', color),
          { type: 'spacer' },
          txt(`${dateLabel(data.due)}还`, 10, 'semibold', C.sub),
        ],
      },
      ...(compact ? [] : [
        { type: 'stack', height: 1, backgroundColor: C.line 
        },
        {
          type: 'stack',
          direction: 'row',
          children: [
            txt('本次消费出账', 11, 'regular', C.sub),
            { type: 'spacer' },
            txt(dateLabel(data.statement), 11, 'semibold'),
          ],
        },
      ]),
    ],
  };
}

function smallWidget(cards, pick) {
  const first = cards[0];
  const second = cards[1];
  const third = cards[2];
  return {
    type: 'widget',
    padding: 14,
    gap: 8,
    backgroundColor: C.bg,
    children: [
      txt('今日刷卡', 13, 'bold'),
      txt(pick.title.replace('今天', ''), 16, 'bold', pick.color),
      txt(pick.detail, 11, 'medium', C.sub),
      { type: 'spacer' },
      {
        type: 'stack',
        direction: 'row',
        children: [
          txt(`${first.shortName} ${first.data.days}天`, 11, 'semibold'),
          { type: 'spacer' },
          txt(`${second.shortName} ${second.data.days}天`, 11, 'semibold'),
        ],
      },
      {
        type: 'stack',
        direction: 'row',
        children: [
          txt(`第3名 ${third.shortName}`, 10, 'medium', C.sub),
          { type: 'spacer' },
          txt(`${third.data.days}天`, 10, 'semibold'),
        ],
      },
    ],
  };
}

function mediumWidget(cards, pick) {
  const metricCell = (card) => {
    const isRecommended = card.data.days === pick.days;
    return {
      type: 'stack',
      direction: 'column',
      flex: 1,
      gap: 4,
      padding: 8,
      backgroundColor: isRecommended
        ?
        { light: '#F0FFF5', dark: '#142219' }
        : C.panel,
      borderRadius: 6,
      borderWidth: 1,
      borderColor: isRecommended ?
      C.accent : { light: '#00000000', dark: '#00000000' },
      children: [
        {
          type: 'stack',
          direction: 'row',
          alignItems: 'center',
          children: [
            txt(card.name, 9, 'semibold', isRecommended ? C.text : C.sub),
            mono(` ${card.tail}`, 8, 
            'medium', C.sub),
            { type: 'spacer' },
            ...(isRecommended ? [{
              type: 'stack',
              padding: [2, 4],
              backgroundColor: C.accent,
              borderRadius: 4,
              children: [
                txt('推荐', 7, 'bold', { light: '#FFFFFF', dark: '#071108' }),
              ],
            }] : []),
          ],
        },
        {
          type: 'stack',
          direction: 'row',
          alignItems: 'end',
          children: [
            mono(card.data.days, 20, 'bold', isRecommended ? C.good : C.text),
            txt('天', 8, 'semibold', isRecommended ? C.good : C.sub),
            { type: 'spacer' },
            mono(dateLabel(card.data.due), 8, 'medium', C.sub),
          ],
        },
      ],
    };
  };

  const topCards = cards.slice(0, 3);

  return {
    type: 'widget',
    padding: 16,
    gap: 9,
    backgroundColor: C.bg,
    children: [
      {
        type: 'stack',
        direction: 'row',
        alignItems: 'center',
        children: [
          txt('今日刷卡建议', 11, 'bold'),
          { type: 'spacer' },
          txt('按免息期排序 · 前3名', 9, 'medium', C.sub),
        ],
      },
      {
        type: 'stack',
        direction: 'row',
        alignItems: 'center',
        children: [
          icon('checkmark.circle.fill', C.accent, 16),
          { type: 'spacer', length: 7 },
          txt(pick.title.replace('今天', ''), 18, 'bold'),
        ],
      },
      {
        type: 'stack',
        direction: 'row',
        gap: 6,
        children: topCards.map(metricCell),
      },
    ],
  };
}

function largeWidget(cards, pick) {
  const metricCell = (card) => ({
    type: 'stack',
    direction: 'column',
    flex: 1,
    gap: 2,
    padding: [6, 8],
    backgroundColor: C.panel,
    borderRadius: 6,
    children: [
      {
        type: 'stack',
        direction: 'row',
        alignItems: 'center',
        children: [
          txt(card.name, 10, 'semibold'),
          txt(` ${card.tail}`, 8, 'medium', C.sub),
          { type: 'spacer' },
          txt(card.data.days, 18, 'bold'),
          txt('天', 8, 'bold', C.accent),
        ],
      },
      txt(`${dateLabel(card.data.statement)}出账 · ${dateLabel(card.data.due)}还`, 8, 'medium', C.sub),
    ],
  });
  const rows = [];
  for (let index = 0; index < cards.length; index += 2) {
    const pair = cards.slice(index, index + 2);
    const children = pair.map(metricCell);
    if (children.length === 1) {
      children.push({ type: 'stack', flex: 1, children: [] });
    }
    rows.push({
      type: 'stack',
      direction: 'row',
      gap: 6,
      children,
    });
  }

  return {
    type: 'widget',
    padding: 13,
    gap: 6,
    backgroundColor: C.bg,
    children: [
      {
        type: 'stack', direction: 'row', alignItems: 'end',
        children: [
          {
            type: 'stack', direction: 'column', gap: 1,
            children: [
              txt(pick.title, 16, 'bold', pick.color),
              txt('按今天消费的实际免息期排序', 8, 'medium', C.sub),
            ],
          },
          { type: 'spacer' },
          txt(pick.days, 27, 'bold'),
          txt('DAYS', 8, 'bold', C.accent),
        ],
      },
      ...rows,
    ],
  };
}

export default async function(ctx) {
  const now = new Date();
  
  const cards = [
    // 仅保留的 6 个银行
    { name: '工商银行', shortName: '工行', tail: '0001', data: sameMonthFixedDuePurchase(now, 1, 25) },
    { name: '广发银行', shortName: '广发', tail: '8888', data: nextMonthFixedDuePurchase(now, 13, 2) },
    { name: '兴业银行', shortName: '兴业', tail: '9226', data: sameMonthFixedDuePurchase(now, 3, 23) },
    { name: '招商银行', shortName: '招商', tail: '8209', data: sameMonthFixedDuePurchase(now, 8, 26) },
    { name: '民生银行', shortName: '民生', tail: '2826', data: nextMonthFixedDuePurchase(now, 25, 14) },
    { name: '中信银行', shortName: '中信', tail: '6165', data: nextMonthFixedDuePurchase(now, 14, 3) },
    
    // 其余银行已注释不生效
    /*
    { name: '南京银行', shortName: '南京', tail: '7809', data: nanjingPurchase(now) },
    { name: '交通银行', shortName: '交行', tail: '3324', data: bocomPurchase(now) },
    { name: '平安银行', shortName: '平安', tail: '3218', data: nextMonthFixedDuePurchase(now, 24, 12) },
    { name: '浦发银行', shortName: '浦发', tail: '9723', data: offsetPurchase(now, 28, 20) },
    { name: '农业银行', shortName: '农行', tail: '2975', data: offsetPurchase(now, 16, 19) },
    { name: '邮储银行', shortName: '邮储', tail: '8508', data: offsetPurchase(now, 6, 20) },
    { name: '浙商银行', shortName: '浙商', tail: '0611', data: sameMonthFixedDuePurchase(now, 1, 18) },
    { name: '中国银行', shortName: '中行', tail: '1228', data: offsetPurchase(now, 22, 20) },
    { name: '江苏银行', shortName: '江苏', tail: '1349', data: offsetPurchase(now, 20, 20) },
    */
  ].sort((a, b) => b.data.days - a.data.days || a.name.localeCompare(b.name, 'zh-CN'));
  
  const pick = recommendation(cards);
  const topCards = cards.slice(0, 3);
  
  if (ctx.widgetFamily === 'accessoryInline') {
    return {
      type: 'widget',
      children: [txt(`${pick.title} · ${pick.detail}`, 12, 'semibold')],
    };
  }

  if (ctx.widgetFamily === 'accessoryRectangular') {
    return {
      type: 'widget',
      padding: 8,
      gap: 3,
      children: [
        txt(pick.title, 12, 'bold'),
        txt(topCards.map((card) => `${card.shortName}${card.data.days}天`).join(' · '), 9, 'medium'),
      ],
    };
  }

  if (ctx.widgetFamily === 'systemSmall') return smallWidget(topCards, pick);
  if (ctx.widgetFamily === 'systemMedium') return mediumWidget(topCards, pick);
  return largeWidget(topCards, pick);
}
