const pad = (n) => String(n).padStart(2, '0');
const dayMs = 24 * 60 * 60 * 1000;

function localDay(date) {
  return new Date(date.getFullYear(), date.getMonth(), date.getDate());
}

function addDays(date, days) {
  const result = new Date(date);
  result.setDate(result.getDate() + days);
  return result;
}

function daysInclusive(from, to) {
  return Math.floor((localDay(to) - localDay(from)) / dayMs) + 1;
}

function dateLabel(date) {
  return `${pad(date.getMonth() + 1)}月${pad(date.getDate())}日`;
}

// 南京银行：12日消费计入当期账单，到期日为账单日后第25天。
function nanjingPurchase(now) {
  const statementMonth = now.getDate() <= 12
    ?
    now.getMonth()
    : now.getMonth() + 1;
  const statement = new Date(now.getFullYear(), statementMonth, 12);
  const due = addDays(statement, 25);
  return { statement, due, days: daysInclusive(now, due) };
}

// 招商银行：按18日当天计入当期账单的保守口径计算，固定次月6日还款。
function cmbPurchase(now) {
  const statementMonth = now.getDate() <= 18
    ?
    now.getMonth()
    : now.getMonth() + 1;
  const statement = new Date(now.getFullYear(), statementMonth, 18);
  const due = new Date(statement.getFullYear(), statement.getMonth() + 1, 6);
  return { statement, due, days: daysInclusive(now, due) };
}

function offsetPurchase(now, statementDay, offsetDays) {
  const statementMonth = now.getDate() <= statementDay
    ?
    now.getMonth()
    : now.getMonth() + 1;
  const statement = new Date(now.getFullYear(), statementMonth, statementDay);
  const due = addDays(statement, offsetDays);
  return { statement, due, days: daysInclusive(now, due) };
}

function nextMonthFixedDuePurchase(now, statementDay, dueDay) {
  const statementMonth = now.getDate() <= statementDay
    ?
    now.getMonth()
    : now.getMonth() + 1;
  const statement = new Date(now.getFullYear(), statementMonth, statementDay);
  const due = new Date(statement.getFullYear(), statement.getMonth() + 1, dueDay);
  return { statement, due, days: daysInclusive(now, due) };
}

function sameMonthFixedDuePurchase(now, statementDay, dueDay) {
  const statementMonth = now.getDate() <= statementDay
    ?
    now.getMonth()
    : now.getMonth() + 1;
  const statement = new Date(now.getFullYear(), statementMonth, statementDay);
  const due = new Date(statement.getFullYear(), statement.getMonth(), dueDay);
  return { statement, due, days: daysInclusive(now, due) };
}

// 兴业银行：26日出账，到期日为账单日后第20天。
function industrialPurchase(now) {
  const statementMonth = now.getDate() <= 26
    ?
    now.getMonth()
    : now.getMonth() + 1;
  const statement = new Date(now.getFullYear(), statementMonth, 26);
  const due = addDays(statement, 20);
  return { statement, due, days: daysInclusive(now, due) };
}

// 交通银行：27日出账，固定次月21日还款。
function bocomPurchase(now) {
  const statementMonth = now.getDate() <= 27
    ?
    now.getMonth()
    : now.getMonth() + 1;
  const statement = new Date(now.getFullYear(), statementMonth, 27);
  const due = new Date(statement.getFullYear(), statement.getMonth() + 1, 21);
  return { statement, due, days: daysInclusive(now, due) };
}

function txt(value, size, weight = 'regular', color = C.text, extra = {}) {
  return {
    type: 'text',
    text: String(value),
    font: { size, weight },
    textColor: color,
    maxLines: 1,
    minScale: 0.65,
    ...extra,
  };
}

function mono(value, size, weight = 'regular', color = C.text, extra = {}) {
  return txt(value, size, weight, color, {
    ...extra,
    font: { size, weight, family: 'Menlo' },
  });
}

function icon(name, color, size = 16) {
  return {
    type: 'image',
    src: `sf-symbol:${name}`,
    color,
    width: size,
    height: size,
  };
}

function recommendation(cards) {
  const maxDays = Math.max(...cards.map((card) => card.data.days));
  const winners = cards.filter((card) => card.data.days === maxDays);
  const lowerDays = cards
    .filter((card) => card.data.days < maxDays)
    .map((card) => card.data.days);
  const nextBest = lowerDays.length ? Math.max(...lowerDays) : maxDays;

  if (winners.length === cards.length) {
    return {
      title: '今天所有卡一样划算',
      detail: `免息期均为${maxDays}天`,
      color: C.good,
      days: maxDays,
    };
  }

  const labelPriority = { '招商银行': 0, '南京银行': 1 };
  const names = [...winners]
    .sort((a, b) => (labelPriority[a.name] ?? 10) - (labelPriority[b.name] ?? 10))
    .map((card) => card.name)
    .join('与');
  return {
    title: `优先刷${names}`,
    detail: winners.length > 1
      ?
      `并列最长${maxDays}天`
      : `免息期多${maxDays - nextBest}天`,
    color: C.good,
    days: maxDays,
  };
}

