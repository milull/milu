          ] : []),
        ],
      },
      {
        type: 'stack',
        height: 0.5,
        backgroundColor: C.line,
      },
      ...rows,
    ],
  };
}

export default async function(ctx) {
  const now = new Date();

  const cards = [
    { name: '中信银行', shortName: '中信', tail: '6165', data: calculateCard(now, 14, 3, 1) },
    { name: '广发银行', shortName: '广发', tail: '8888', data: calculateCard(now, 13, 2, 1) },
    { name: '招商银行', shortName: '招商', tail: '8209', data: calculateCard(now, 8, 26, 0) },
    { name: '工商银行', shortName: '工行', tail: '0001', data: calculateCard(now, 1, 25, 0) },
    { name: '兴业银行', shortName: '兴业', tail: '9226', data: calculateCard(now, 3, 23, 0) },
    { name: '民生银行', shortName: '民生', tail: '2826', data: calculateCard(now, 25, 14, 1) },
  ];

  const sortedCards = [...cards].sort((a, b) => {
    const aDays = a.data.recommendToday ? a.data.daysToday : 0;
    const bDays = b.data.recommendToday ? b.data.daysToday : 0;
    return bDays - aDays || a.name.localeCompare(b.name, 'zh-CN');
  });

  const pick = recommendation(sortedCards);

  if (ctx.widgetFamily === 'accessoryInline') {
    const urgent = dueSoonCards(sortedCards, now)[0];
    const text = urgent
      ? `${urgent.shortName} ${urgent.data.remaining <= 0 ? '今天还款' : `${urgent.data.remaining}天后还款`}`
      : `${pick.title} · ${pick.detail}`;
    return {
      type: 'widget',
      children: [txt(text, 12, 'semibold')],
    };
  }

  if (ctx.widgetFamily === 'accessoryRectangular') {
    const urgent = dueSoonCards(sortedCards, now)[0];
    return {
      type: 'widget',
      padding: 8,
      gap: 3,
      children: [
        txt(pick.title, 12, 'bold'),
        urgent
          ? txt(
              `⚠️ ${urgent.shortName} ${urgent.data.remaining <= 0 ? '今天还款' : `${urgent.data.remaining}天后还款`}`,
              9, 'medium', dueSoonColor(urgent.data.remaining)
            )
          : txt(sortedCards.slice(0, 3).filter(c => c.data.recommendToday).map(c => `${c.shortName}${c.data.daysToday}天`).join(' · '), 9, 'medium'),
      ],
    };
  }

  if (ctx.widgetFamily === 'systemSmall') {
    const first = sortedCards.filter(c => c.data.recommendToday)[0];
    const second = sortedCards.filter(c => c.data.recommendToday)[1];
    const third = sortedCards.filter(c => c.data.recommendToday)[2];
    const urgent = dueSoonCards(sortedCards, now)[0];
    return {
      type: 'widget',
      padding: 14,
      gap: 8,
      backgroundColor: C.bg,
      children: [
        txt('今日刷卡', 13, 'bold'),
        txt(pick.title, 16, 'bold', pick.color),
        txt(pick.detail, 11, 'medium', C.sub),
        ...(urgent ? [
          {
            type: 'stack',
            direction: 'row',
            alignItems: 'center',
            gap: 4,
            children: [
              icon('exclamationmark.triangle.fill', dueSoonColor(urgent.data.remaining), 11),
              txt(
                `${urgent.shortName} ${urgent.data.remaining <= 0 ? '今天还款' : `${urgent.data.remaining}天后还款`}`,
                10, 'semibold', dueSoonColor(urgent.data.remaining)
              ),
            ],
          },
        ] : []),
        { type: 'spacer' },
        ...(first ? [{
          type: 'stack',
          direction: 'row',
          children: [
            txt(`${first.shortName} ${first.data.daysToday}天`, 11, 'semibold'),
            { type: 'spacer' },
            txt(second ? `${second.shortName} ${second.data.daysToday}天` : '—', 11, 'semibold'),
          ],
        }] : []),
        ...(third ? [{
          type: 'stack',
          direction: 'row',
          children: [
            txt(`第3名 ${third.shortName}`, 10, 'medium', C.sub),
            { type: 'spacer' },
            txt(`${third.data.daysToday}天`, 10, 'semibold'),
          ],
        }] : []),
      ],
    };
  }

  if (ctx.widgetFamily === 'systemMedium') {
    return mediumWidget(sortedCards, pick, now);
  }
  
  return largeWidget(sortedCards, pick, now);
}