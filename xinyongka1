  const rows = [];
  for (let i = 0; i < displayCards.length; i += 2) {
    const rowItems = displayCards.slice(i, i + 2);
    rows.push({
      type: 'stack',
      direction: 'row',
      gap: 8,
      children: rowItems.map(item => renderItem(item)),
    });
  }

  return {
    type: 'widget',
    padding: 10,
    gap: 6,
